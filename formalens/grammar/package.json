{
  "name": "tree-sitter-formalang",
  "version": "0.1.0",
  "description": "FormaLang grammar for tree-sitter",
  "main": "bindings/node",
  "types": "bindings/node",
  "repository": {
    "type": "git",
    "url": "https://github.com/valentinradu/formalang"
  },
  "keywords": [
    "tree-sitter",
    "parser",
    "formalang"
  ],
  "files": [
    "grammar.js",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**"
  ],
  "author": "Valentin Radu",
  "license": "MIT",
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0",
    "prebuildify": "^6.0.0"
  },
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "build": "tree-sitter generate && tree-sitter build",
    "parse": "tree-sitter parse",
    "install": "node-gyp-build",
    "prebuildify": "prebuildify --napi --strip"
  },
  "tree-sitter": [
    {
      "scope": "source.formalang",
      "file-types": [
        "fv"
      ],
      "injection-regex": "^formalang$",
      "highlights": "queries/highlights.scm",
      "folds": "queries/folds.scm"
    }
  ],
  "dependencies": {
    "node-gyp-build": "^4.8.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.21.0"
  },
  "peerDependenciesMeta": {
    "tree_sitter": {
      "optional": true
    }
  }
}
