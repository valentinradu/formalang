{
  "files.associations": {
    "*.fv": "rust"
  },
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "[rust]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "rust-analyzer.files.excludeDirs": [
    "*.fv",
    "stdlib.fv",
    "formalens/grammar"
  ],
  "rust-analyzer.linkedProjects": [
    "formalens/semantic/Cargo.toml"
  ],
  "search.exclude": {
    "**/node_modules": true,
    "**/target": true,
    "**/.formalens": true,
    "**/formalens/grammar/src/parser.c": true,
    "**/.fastembed_cache": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/target": true,
    "**/.fastembed_cache": true
  }
}
