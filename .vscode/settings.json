{
  "files.associations": {
    "*.fv": "rust"
  },
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "[rust]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "rust-analyzer.files.excludeDirs": [
    "*.fv",
    "docs/user/stdlib.fv"
  ],
  "search.exclude": {
    "**/node_modules": true,
    "**/target": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/target": true
  }
}
